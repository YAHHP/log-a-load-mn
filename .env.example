# Public hosted checkout links only.
# These are safe to expose because they are destination URLs, not secret API keys.
# Do not add Stripe secret keys, PayPal client secrets, webhook secrets, or admin passwords here.

VITE_PAYPAL_TICKETS_URL=
VITE_PAYPAL_DONATE_URL=
VITE_VENMO_PROFILE_URL=
VITE_STRIPE_TICKETS_URL=
VITE_STRIPE_DONATE_URL=
VITE_API_BASE_URL=http://127.0.0.1:8787

# Optional demo-only admin preview gate.
# Leave disabled on public GitHub Pages. This is not production authentication.
VITE_ENABLE_ADMIN_DEMO=false
VITE_ADMIN_DEMO_CODE=

# Backend V1 local/server-only values. Do not expose these in frontend env vars.
PORT=8787
HOST=127.0.0.1
LOGALOAD_DATA_FILE=server/data/local-db.json
ADMIN_PASSWORD=change-this-before-sharing-admin
ADMIN_SESSION_SECRET=change-this-long-random-session-secret
CORS_ORIGINS=http://127.0.0.1:5177,http://localhost:5177
WEBHOOK_SHARED_SECRET=
